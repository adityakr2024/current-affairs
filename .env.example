# The Currents — environment variables
# Copy to .env for local runs. In GitHub Actions, add each as a Repository Secret.

# ── Groq (free, heavy enrichment) ────────────────────────────────────────────
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# ── Cerebras (free, fast 70b, enrichment) ────────────────────────────────────
CEREBRAS_API_KEY_1=

# ── Gemini Flash (free, light tasks: oneliners, captions) ────────────────────
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# ── OpenAI gpt-4o-mini (paid, good quality, enrich + oneliners) ──────────────
OPENAI_API_KEY_1=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=

# ── OpenRouter (free small model, light fallback) ────────────────────────────
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=

# ── Anthropic Claude (paid, enrich fallback) ─────────────────────────────────
ANTHROPIC_API_KEY_1=

# ── Delivery (optional — system runs without these) ──────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GMAIL_SENDER=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENT=

# ── Output directory (optional, defaults to /tmp/the_currents) ───────────────
# OUTPUT_DIR=/path/to/output
